# =====================================================
# Railway 环境变量配置指南
# 
# ⚠️ 不要将此文件提交到 GitHub！
# 在 Railway Dashboard 中手动添加这些环境变量
# =====================================================

# ==================== 数据库配置（Railway MySQL 插件）====================
# Railway 会自动提供这些变量，但你可以覆盖：
DB_HOST=${{MySQL.HOST}}
DB_PORT=${{MySQL.PORT}}
DB_USER=${{MySQL.USER}}
DB_PASSWORD=${{MySQL.PASSWORD}}
DB_NAME=${{MySQL.DATABASE}}
DB_CHARSET=utf8mb4

# 如果使用外部数据库，请手动设置：
# DB_HOST=your-mysql-host.railway.app
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-secure-password
# DB_NAME=erp_system

# ==================== JWT安全配置（必须修改！）====================
# 使用命令生成: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-generated-jwt-secret-key-here-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== Flask安全配置 ====================
SECRET_KEY=your-flask-secret-key-here-different-from-jwt-key

# 环境设置（Railway 自动设置为 production）
FLASK_ENV=production
FLASK_DEBUG=False

# ==================== CORS跨域配置 ====================
# 设置为你的实际域名，或使用 * 允许所有（不推荐生产环境）
CORS_ORIGINS=https://your-app-name.up.railway.app

# ==================== 会话安全配置 ====================
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ==================== 密码策略配置 ====================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=False

# ==================== 文件上传配置 ====================
MAX_CONTENT_LENGTH_MB=16

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=${{PORT}}  # Railway 动态分配端口
WORKERS=2      # Railway 推荐使用较少的 workers

# ==================== Railway 特定配置 ====================
# Railway 会自动设置 PORT 变量，应用必须监听此端口
